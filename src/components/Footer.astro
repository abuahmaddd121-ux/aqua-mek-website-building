---
import { getContent } from '@/i18n/content';
import { localizePath, type Lang } from '@/i18n/ui';
import { brand, links } from '@/data/business';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = getContent(lang);
const year = 2026;
---
<footer class="bg-navy-900 text-white/80">
  <div class="container-x grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <!-- brand -->
    <div class="lg:col-span-1">
      <span class="text-xl font-extrabold tracking-tight text-white">AQUA <span class="text-aqua-400">№1</span></span>
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-white/60">{c.footer.about}</p>
    </div>

    <!-- quick links -->
    <nav aria-label="Footer">
      <h3 class="text-sm font-bold uppercase tracking-wide text-white">{c.footer.quickLinks}</h3>
      <ul class="mt-4 space-y-2.5 text-sm">
        {
          c.nav.map((item) => (
            <li>
              <a href={localizePath(item.path, lang)} class="text-white/70 transition-colors hover:text-aqua-300">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- contact -->
    <div>
      <h3 class="text-sm font-bold uppercase tracking-wide text-white">{c.footer.contact}</h3>
      <ul class="mt-4 space-y-3 text-sm">
        <li>
          <a href={links.tel} class="flex items-center gap-2.5 text-white/70 hover:text-aqua-300">
            <Icon name="phone" class="h-4 w-4 text-aqua-400" />
            {brand.phoneDisplay}
          </a>
        </li>
        <li>
          <a href={links.email} class="flex items-center gap-2.5 break-all text-white/70 hover:text-aqua-300">
            <Icon name="mail" class="h-4 w-4 text-aqua-400" />
            {brand.email}
          </a>
        </li>
        <li class="flex items-center gap-2.5 text-white/70">
          <Icon name="pin" class="h-4 w-4 text-aqua-400" />
          {c.contact.cityValue}
        </li>
      </ul>
    </div>

    <!-- reach us -->
    <div>
      <h3 class="text-sm font-bold uppercase tracking-wide text-white">{c.contact.socialLabel}</h3>
      <div class="mt-4 flex flex-wrap gap-2.5">
        <a href={links.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp"
           class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition-colors hover:bg-aqua-500">
          <Icon name="whatsapp" class="h-5 w-5" />
        </a>
        <a href={links.viber} aria-label="Viber"
           class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition-colors hover:bg-aqua-500">
          <Icon name="viber" class="h-5 w-5" />
        </a>
        <a href={brand.instagramUrl} target="_blank" rel="noopener" aria-label="Instagram"
           class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition-colors hover:bg-aqua-500">
          <Icon name="instagram" class="h-5 w-5" />
        </a>
      </div>
      <p class="mt-3 text-sm text-white/50">{brand.instagramHandle}</p>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-x flex flex-col items-center justify-between gap-2 py-5 text-xs text-white/50 sm:flex-row">
      <p>© {year} AQUA №1. {c.footer.rights}</p>
      <p>{c.tagline}</p>
    </div>
  </div>
</footer>
