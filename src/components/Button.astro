---
/** Button / link with brand variants. Renders <a> when href is given, else <button>. */
interface Props {
  href?: string;
  type?: 'button' | 'submit';
  variant?: 'primary' | 'secondary' | 'white' | 'outlineWhite' | 'ghost';
  size?: 'md' | 'lg';
  class?: string;
  [key: string]: unknown;
}
const {
  href,
  type = 'button',
  variant = 'primary',
  size = 'md',
  class: className = '',
  ...rest
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-full font-semibold transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua-400 focus-visible:ring-offset-2';

const variants: Record<string, string> = {
  primary: 'bg-aqua-500 text-white hover:bg-aqua-600 shadow-lg shadow-aqua-500/25',
  secondary: 'bg-white text-navy-900 ring-1 ring-navy-900/10 hover:bg-aqua-50 hover:ring-aqua-200',
  white: 'bg-white text-aqua-700 hover:bg-aqua-50 shadow-lg shadow-navy-900/10',
  outlineWhite: 'border border-white/70 text-white hover:bg-white/10',
  ghost: 'text-navy-700 hover:text-aqua-600',
};

const sizes: Record<string, string> = {
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3.5 text-base',
};

const cls = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
---
{
  href ? (
    <a href={href} class={cls} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={cls} {...rest}>
      <slot />
    </button>
  )
}
