---
import { Image } from 'astro:assets';
import { getContent } from '@/i18n/content';
import { localizePath, stripLang, type Lang } from '@/i18n/ui';
import { brand, links, logoImg } from '@/data/business';
import Icon from './Icon.astro';
import Button from './Button.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = getContent(lang);
const current = stripLang(Astro.url.pathname);
const isActive = (path: string) =>
  path === '/' ? current === '/' : current.startsWith(path);
const orderHref = localizePath('/contact', lang);
---
<header class="sticky top-0 z-50 border-b border-navy-900/5 bg-white/90 backdrop-blur supports-[backdrop-filter]:bg-white/75">
  <!-- thin announcement strip -->
  <div class="bg-navy-900 text-white">
    <div class="container-x flex h-9 items-center justify-between text-[11px] sm:text-xs">
      <span class="hidden items-center gap-1.5 min-[360px]:flex">
        <Icon name="truck" class="h-3.5 w-3.5 text-aqua-300" />
        {c.offers.freeDelivery.title}
      </span>
      <a href={links.tel} class="flex items-center gap-1.5 font-semibold hover:text-aqua-300">
        <Icon name="phone" class="h-3.5 w-3.5" />
        {brand.phoneDisplay}
      </a>
    </div>
  </div>

  <div class="container-x flex h-16 items-center justify-between gap-4">
    <!-- logo -->
    <a href={localizePath('/', lang)} class="flex items-center gap-2.5" aria-label={brand.name}>
      <Image src={logoImg} alt={brand.name} width={44} height={44} class="h-11 w-11 rounded-full" />
      <span class="flex flex-col leading-none">
        <span class="text-lg font-extrabold tracking-tight text-navy-900">AQUA <span class="text-aqua-500">№1</span></span>
        <span class="hidden text-[10px] font-medium text-navy-700/60 sm:block">{c.tagline}</span>
      </span>
    </a>

    <!-- desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {
        c.nav.map((item) => (
          <a
            href={localizePath(item.path, lang)}
            aria-current={isActive(item.path) ? 'page' : undefined}
            class={`rounded-full px-3.5 py-2 text-sm font-medium transition-colors ${
              isActive(item.path)
                ? 'text-aqua-600'
                : 'text-navy-900/80 hover:bg-aqua-50 hover:text-aqua-600'
            }`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <LanguageSwitcher lang={lang} class="hidden sm:flex" />
      <Button href={orderHref} variant="primary" size="md" class="hidden sm:inline-flex">
        <Icon name="droplet" class="h-4 w-4" />
        {c.cta.order}
      </Button>
      <!-- mobile menu button -->
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-navy-900 hover:bg-aqua-50 lg:hidden"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" class="h-6 w-6" data-icon-open />
        <Icon name="close" class="hidden h-6 w-6" data-icon-close />
      </button>
    </div>
  </div>

  <!-- mobile menu panel -->
  <div id="mobile-menu" class="hidden border-t border-navy-900/5 bg-white lg:hidden">
    <nav class="container-x flex flex-col gap-1 py-4" aria-label="Mobile">
      {
        c.nav.map((item) => (
          <a
            href={localizePath(item.path, lang)}
            aria-current={isActive(item.path) ? 'page' : undefined}
            class={`rounded-xl px-4 py-3 text-base font-medium ${
              isActive(item.path) ? 'bg-aqua-50 text-aqua-600' : 'text-navy-900 hover:bg-aqua-50'
            }`}
          >
            {item.label}
          </a>
        ))
      }
      <div class="mt-3 flex items-center justify-between border-t border-navy-900/5 pt-4">
        <LanguageSwitcher lang={lang} />
        <Button href={orderHref} variant="primary" size="md">
          <Icon name="droplet" class="h-4 w-4" />
          {c.cta.order}
        </Button>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = toggle?.querySelector('[data-icon-open]');
  const closeIcon = toggle?.querySelector('[data-icon-close]');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    openIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
  });
</script>
