---
import { Image } from 'astro:assets';
import type { Product } from '@/data/business';
import { brand, links } from '@/data/business';
import { getContent } from '@/i18n/content';
import type { Lang } from '@/i18n/ui';
import Icon from './Icon.astro';

interface Props {
  product: Product;
  lang: Lang;
}
const { product, lang } = Astro.props;
const c = getContent(lang);
---
<div
  class="group relative flex flex-col items-center rounded-2xl border border-navy-900/5 bg-white p-5 text-center shadow-sm transition duration-200 hover:-translate-y-1 hover:border-aqua-200 hover:shadow-lg hover:shadow-aqua-500/10"
  data-product
  data-size={product.size}
  data-wa={links.whatsapp}
  data-prefix={c.products.orderPrefix}
>
  {
    product.popular && (
      <span class="absolute left-1/2 top-3 z-10 -translate-x-1/2 whitespace-nowrap rounded-full bg-aqua-500 px-3 py-1 text-[11px] font-bold text-white shadow-sm">
        {c.products.badge}
      </span>
    )
  }
  <div class="relative flex h-40 w-full items-center justify-center">
    <div class="absolute inset-x-6 bottom-2 h-16 rounded-full bg-aqua-100/60 blur-2xl"></div>
    <Image
      src={product.image}
      alt={`${brand.name} ${product.size}`}
      width={160}
      height={200}
      class="relative h-full w-auto object-contain drop-shadow-md transition-transform duration-300 group-hover:scale-110"
    />
  </div>
  <p class="mt-4 text-lg font-bold text-navy-900">{product.size}</p>
  <p class="mt-1 text-xl font-extrabold text-aqua-600">
    {product.price.toLocaleString('hy-AM')}
    <span class="text-sm font-bold text-aqua-500">{c.currencyLabel}</span>
  </p>

  <!-- quantity stepper -->
  <div class="mt-4 inline-flex items-center gap-1 rounded-full bg-aqua-50 p-1">
    <button
      type="button"
      data-step="-1"
      aria-label="−"
      class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white text-lg font-bold text-navy-900 shadow-sm transition hover:bg-aqua-100"
    >−</button>
    <span data-qty class="w-7 text-center text-sm font-bold text-navy-900 tabular-nums">1</span>
    <button
      type="button"
      data-step="1"
      aria-label="+"
      class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white text-lg font-bold text-navy-900 shadow-sm transition hover:bg-aqua-100"
    >+</button>
  </div>

  <!-- order via WhatsApp -->
  <button
    type="button"
    data-order
    class="mt-3 inline-flex w-full items-center justify-center gap-1.5 rounded-full bg-aqua-500 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-aqua-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua-400 focus-visible:ring-offset-2"
  >
    <Icon name="droplet" class="h-4 w-4" />
    {c.cta.order}
  </button>
</div>

<script>
  // Quantity steppers + WhatsApp order, delegated so it covers every card on the page.
  const clampQty = (n: number) => Math.max(1, Math.min(99, n));

  document.addEventListener('click', (e) => {
    const el = e.target as HTMLElement;

    const step = el.closest<HTMLElement>('[data-step]');
    if (step) {
      const card = step.closest<HTMLElement>('[data-product]');
      const qtyEl = card?.querySelector<HTMLElement>('[data-qty]');
      if (qtyEl) {
        const next = clampQty(parseInt(qtyEl.textContent || '1', 10) + Number(step.dataset.step));
        qtyEl.textContent = String(next);
      }
      return;
    }

    const order = el.closest<HTMLElement>('[data-order]');
    if (order) {
      const card = order.closest<HTMLElement>('[data-product]');
      if (!card) return;
      const qty = card.querySelector<HTMLElement>('[data-qty]')?.textContent || '1';
      const text = `${card.dataset.prefix}: ${card.dataset.size} × ${qty}`;
      window.open(`${card.dataset.wa}?text=${encodeURIComponent(text)}`, '_blank');
    }
  });
</script>
