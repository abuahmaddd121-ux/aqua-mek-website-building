const isStroke = STROKE.has(name);
---
<svg
  viewBox="0 0 24 24"
  class={className}
  fill={isStroke ? 'none' : 'currentColor'}
  stroke={isStroke ? 'currentColor' : 'none'}
  stroke-width={isStroke ? 1.7 : 0}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={ICONS[name]}
/>
