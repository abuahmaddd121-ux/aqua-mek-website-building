---
import { links } from '@/data/business';
import Icon from './Icon.astro';
---
<a
  href={links.whatsapp}
  target="_blank"
  rel="noopener"
  aria-label="WhatsApp"
  class="fixed bottom-5 right-5 z-40 inline-flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-xl shadow-[#25D366]/30 transition-transform hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
>
  <Icon name="whatsapp" class="h-7 w-7" />
</a>
