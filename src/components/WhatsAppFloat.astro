---
import { links } from '@/data/business';
import Icon from './Icon.astro';
---
<a
  href={links.whatsapp}
  target="_blank"
  rel="noopener"
  aria-label="WhatsApp"
  class="fixed bottom-4 right-4 z-40 inline-flex h-12 w-12 items-center justify-center rounded-full bg-[#25D366] text-white shadow-xl shadow-[#25D366]/30 transition-transform hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white sm:bottom-5 sm:right-5 sm:h-14 sm:w-14"
>
  <Icon name="whatsapp" class="h-6 w-6 sm:h-7 sm:w-7" />
</a>
