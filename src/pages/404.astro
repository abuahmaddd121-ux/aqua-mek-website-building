---
import Base from '@/layouts/Base.astro';
import Button from '@/components/Button.astro';
import Icon from '@/components/Icon.astro';
import { getContent } from '@/i18n/content';
import { localizePath } from '@/i18n/ui';

const lang = 'hy';
const c = getContent(lang);
---
<Base lang={lang} title="404 | AQUA №1" description="Էջը չի գտնվել" path="/404">
  <section class="container-x flex flex-col items-center py-24 text-center lg:py-32">
    <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-aqua-50 text-aqua-500">
      <Icon name="droplet" class="h-8 w-8" />
    </div>
    <p class="mt-6 text-6xl font-extrabold text-aqua-500">404</p>
    <h1 class="mt-3 text-2xl font-bold text-navy-900">Էջը չի գտնվել</h1>
    <p class="mt-3 max-w-md text-navy-900/60">Հնարավոր է՝ էջը տեղափոխվել է կամ այլևս գոյություն չունի։</p>
    <div class="mt-8">
      <Button href={localizePath('/', lang)} variant="primary" size="lg">
        <Icon name="arrow-right" class="h-5 w-5" />
        Վերադառնալ գլխավոր
      </Button>
    </div>
  </section>
</Base>
